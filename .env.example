# Required: Groq API key (free tier at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# LLM settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
MAX_ANSWER_TOKENS=500

# Embedding model (local; downloads on first run, ~130 MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Paths
CORPUS_DIR=./corpus
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=northwind_policies

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval
RETRIEVAL_K=5
FETCH_K=20
USE_MMR=false
USE_RERANKER=true

# Flask app
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false

# Determinism
RANDOM_SEED=42
